// ignore_for_file: type=lint
mixin _$SetCollectionDaoMixin on DatabaseAccessor<AppDatabase> {
  $SetsTable get sets => attachedDatabase.sets;
  $EntitiesTable get entities => attachedDatabase.entities;
  $SetRequirementsTable get setRequirements => attachedDatabase.setRequirements;
  $CollectionsTable get collections => attachedDatabase.collections;
  $CollectionEntitiesTable get collectionEntities =>
      attachedDatabase.collectionEntities;
  $ExpeditionsTable get expeditions => attachedDatabase.expeditions;
}
