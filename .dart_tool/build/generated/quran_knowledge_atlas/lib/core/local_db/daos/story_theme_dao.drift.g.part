// ignore_for_file: type=lint
mixin _$StoryThemeDaoMixin on DatabaseAccessor<AppDatabase> {
  $StoriesTable get stories => attachedDatabase.stories;
  $StoryVerseRangesTable get storyVerseRanges =>
      attachedDatabase.storyVerseRanges;
  $ThemesTable get themes => attachedDatabase.themes;
  $ThemeLevelsTable get themeLevels => attachedDatabase.themeLevels;
  $ThemeTriggersTable get themeTriggers => attachedDatabase.themeTriggers;
}
